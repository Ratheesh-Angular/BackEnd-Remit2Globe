# Production template — copy to `.env.production` only on your machine for smoke tests.
# On Render, set these variables in the service dashboard (no `.env` file upload).

DATABASE_URL="postgresql://USER:PASSWORD@dpg-xxxxx-a.<REGION>-postgres.render.com/DATABASE?sslmode=require"
JWT_SECRET="<generate-a-strong-secret>"
JWT_EXPIRES_IN="7d"

# Matches cbp-frontend INTERNAL_FRONTEND_AUTH_SECRET
INTERNAL_FRONTEND_AUTH_SECRET="<long-random-string-match-frontend>"

PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-frontend.onrender.com

# CORS_ORIGINS=https://your-frontend.onrender.com

OTP_SKIP_CODE_VALIDATION=false

ADMIN_API_KEY="<same-as-cbp-admin-CBP_ADMIN_API_KEY-if-used>"

AWS_ACCESS_KEY_ID="<IAM>"
AWS_SECRET_ACCESS_KEY="<secret>"
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-bucket

FLEX_BASE_URL=https://testbed.flex-money.tech
FLEX_CLIENT_ID=
FLEX_CLIENT_SECRET=
FLEX_USER_CODE=
FLEX_RAW_PASSWORD=
